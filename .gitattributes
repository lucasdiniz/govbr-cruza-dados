# Forcar LF em scripts/units que rodam em Linux na VM, mesmo se editados no Windows.
# Sem isso, bash/systemd quebram silenciosamente em caracteres `\r`.
*.sh        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf
*.sql       text eol=lf
deploy/nginx-cruza.conf text eol=lf
